  refine ⟨rfl, ?_⟩
  intro t h
  cases t <;> first | rfl | (exfalso; exact h rfl) | decide

/-- Criterion (E) cross-sector identities: NO candidate scores 3.
    The framework's cross-sector identities are PRIMORDIAL FRAMEWORK
    CONTENT, not derived from any of the seven TOE candidates. -/
theorem critE_no_max_scorer (t : TOE) :
    score t .crossSectorId < MAX_SCORE := by
  cases t <;> decide

/-- Criterion (F) SO(10) compatibility: T1, T2, Hybrid all score 3
    (SO(10) is by definition built into T1 and Hybrid; string can
    accommodate SO(10)). -/
theorem critF_max_scorers :
    score .CausalSet_SO10 .SO10Compat = MAX_SCORE
    ∧ score .StringMtheory .SO10Compat = MAX_SCORE
    ∧ score .Hybrid .SO10Compat = MAX_SCORE := by
  refine ⟨rfl, rfl, rfl⟩

