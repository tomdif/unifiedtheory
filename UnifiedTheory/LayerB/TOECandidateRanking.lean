    -- |imaginary octonions| = 7 = disc
    (7 : ℕ) = TOE_disc
    -- dim(SU(3)) = N_W^3
    ∧ (8 : ℕ) = TOE_NW ^ 3
    -- dim(G₂) = 14 = N_W · disc
    ∧ (14 : ℕ) = TOE_NW * TOE_disc
    -- the three triality reps deliver N_g = N_c
    ∧ N_g = TOE_Nc := by
  refine ⟨?_, ?_, ?_, ?_⟩
  · unfold TOE_disc atom_disc; rfl
  · unfold TOE_NW atom_N_W; rfl
  · unfold TOE_NW TOE_disc atom_N_W atom_disc; rfl
  · unfold N_g TOE_Nc atom_N_c; rfl

