/-- A falsification predicate: "candidate t scores higher than Hybrid
    on at least one criterion". -/
def beats_hybrid_on_some_criterion (t : TOE) : Prop :=
  ∃ c : Criterion, score t c > score .Hybrid c

/-- Currently NO single candidate beats Hybrid on any criterion: the
    Hybrid is component-wise dominant. -/
theorem no_singleton_beats_hybrid_on_any_criterion :
    ¬ beats_hybrid_on_some_criterion .CausalSet_SO10
    ∧ ¬ beats_hybrid_on_some_criterion .StringMtheory
    ∧ ¬ beats_hybrid_on_some_criterion .LoopQuantumGravity
    ∧ ¬ beats_hybrid_on_some_criterion .ConnesSpectralTriples
    ∧ ¬ beats_hybrid_on_some_criterion .OctonionFurey
    ∧ ¬ beats_hybrid_on_some_criterion .CausalDynTriangulation
    ∧ ¬ beats_hybrid_on_some_criterion .AsymptoticSafety := by
  refine ⟨?_, ?_, ?_, ?_, ?_, ?_, ?_⟩ <;>
  · rintro ⟨c, h⟩
    cases c <;> simp [score] at h

