    §9.  RESIDUE CLASSIFICATION FOR THE FULL CONTINUUM
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -/

/-- **CHAMBER-SECTOR ST RESIDUE (DISCHARGED).**

    The chamber-sector residue of the Slavnov-Taylor identities — the
    portion of the full ST identity statement that the framework can
    settle without continuum Faddeev-Popov measure theory — is
    DISCHARGED.

    Statement:

      (a) Every chamber-sector ST sum vanishes.
      (b) Each chamber-sector ST term vanishes individually.
      (c) Nilpotency Q² = 0 holds on every configuration.
      (d) Observable-level nilpotency δ_BRST² = 0 holds on every
          observable.
      (e) The continuum residue (M-INV continuum) remains tagged
          OPEN — it does NOT block the chamber-sector statement. -/
theorem ST_chamber_residue_discharged :
    -- (a) chamber ST sum vanishes
    (∀ (n : ℕ) (F : Fin n → ℝ),
        STsum n (fun j => chamberSpectralObservable (F j)) = 0) ∧
    -- (b) each chamber ST term vanishes individually
    (∀ (n : ℕ) (F : Fin n → ℝ) (i : Fin n),
        STterm n (fun j => chamberSpectralObservable (F j)) i = 0) ∧
    -- (c) Q² = 0
    (∀ X : BRSTConfig, Q (Q X) = 0) ∧
    -- (d) δ_BRST² = 0 (observable-level)
    (∀ O : BRSTConfig → ℝ, deltaBRST (deltaBRST O) = zeroObs) ∧
    -- (e) the continuum residue remains tagged OPEN
    (st_S7.status = STStatus.OpenContinuum) := by
  refine ⟨?_, ?_, ?_, ?_, st_S7_open⟩
  · intro n F; exact ST_chamber_sector n F
  · intro n F i; exact STterm_chamberSpectral_zero n F i
  · exact M_Q_squared_zero
  · intro O; exact deltaBRST_squared_general O

