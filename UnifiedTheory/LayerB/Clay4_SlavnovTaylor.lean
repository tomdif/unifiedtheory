    (st_ledger.filter (fun c => c.status = STStatus.Proved)).length = 5 ∧
    -- 2 CHAMBER-ONLY (S4, S6)
    (st_ledger.filter
      (fun c => c.status = STStatus.ChamberOnly)).length = 2 ∧
    -- 1 OPEN (S7)
    (st_ledger.filter
      (fun c => c.status = STStatus.OpenContinuum)).length = 1 ∧
    -- All 8 accounted for
    (st_ledger.filter (fun c => c.status = STStatus.Proved)).length +
    (st_ledger.filter
      (fun c => c.status = STStatus.ChamberOnly)).length +
    (st_ledger.filter
      (fun c => c.status = STStatus.OpenContinuum)).length = 8 := by
  refine ⟨?_, ?_, ?_, ?_⟩
  · exact st_ledger_proved_count
  · exact st_ledger_chamber_count
  · exact st_ledger_open_count
  · exact st_ledger_total_accounted

