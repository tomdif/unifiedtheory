    §10.  HONEST SCOPE STATEMENT
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -/

/-- **HONEST SCOPE STATEMENT (Clay-4 Slavnov-Taylor identities).**

    What this file proves UNCONDITIONALLY:

      ✓ δ_BRST well-defined on every observable on `BRSTConfig`.
      ✓ δ_BRST kills chamber-spectral observables.
      ✓ Slavnov-Taylor sum well-defined for any n-tuple.
      ✓ Chamber-sector ST identity: every term vanishes individually.
      ✓ (M-Q²) nilpotency Q² = 0.
      ✓ δ_BRST² = 0 (observable-level nilpotency).

    What is CONDITIONAL on chamber-only:

      ⊕ The ST identity itself (proved on chamber, not bath).
      ⊕ (M-INV chamber) chamber-sector measure invariance.

    What remains OPEN at the continuum level:

      ✗ (M-INV continuum) Faddeev-Popov measure invariance under
        the BRST flow in continuum YM.  This is the genuine
        analytic input required for the full ST identities, and is
        outside framework scope.
      ✗ Anomaly cancellation (full theory).
      ✗ Kugo-Ojima quartet mechanism with full state-space analysis.
      ✗ All-loop ST identities for non-abelian YM. -/
theorem honest_ST_scope_statement :
    -- (PROVED) δ_BRST well-defined
    (∀ O : BRSTConfig → ℝ, ∀ X : BRSTConfig,
        deltaBRST O X = O (Q X) - O 0) ∧
    -- (PROVED) δ_BRST kills chamber-spectral observables
    (∀ F : ℝ,
        deltaBRST (chamberSpectralObservable F) = zeroObs) ∧
    -- (PROVED) Chamber-sector ST identity
    (∀ (n : ℕ) (F : Fin n → ℝ),
        STsum n (fun j => chamberSpectralObservable (F j)) = 0) ∧
    -- (PROVED) (M-Q²)
    (∀ X : BRSTConfig, Q (Q X) = 0) ∧
    -- (PROVED) δ_BRST² = 0
    (∀ O : BRSTConfig → ℝ, deltaBRST (deltaBRST O) = zeroObs) ∧
    -- (CHAMBER-ONLY) M-INV
    (∀ (n : ℕ) (F : Fin n → ℝ),
        correlator_vac n
          (fun j => fun X =>
            chamberSpectralObservable (F j) X +
            deltaBRST (chamberSpectralObservable (F j)) X) =
        correlator_vac n
          (fun j => chamberSpectralObservable (F j))) ∧
    -- Status tags
    (st_S4.status = STStatus.ChamberOnly) ∧
    (st_S6.status = STStatus.ChamberOnly) ∧
    -- (OPEN) full continuum FP measure invariance
    (st_S7.status = STStatus.OpenContinuum) := by
  refine ⟨?_, ?_, ?_, ?_, ?_, ?_, st_S4_chamber, st_S6_chamber, st_S7_open⟩
  · intro O X; rfl
  · intro F; exact deltaBRST_chamberSpectral F
  · intro n F; exact ST_chamber_sector n F
  · exact M_Q_squared_zero
  · intro O; exact deltaBRST_squared_general O
  · intro n F; exact M_INV_chamber_sector n F

