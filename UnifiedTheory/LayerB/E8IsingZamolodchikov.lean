/-- **cos is monotone-decreasing on [0, π].**  Standard fact reused. -/
theorem cos_decreasing (x y : ℝ) (hx : 0 ≤ x) (hy : y ≤ Real.pi)
    (hxy : x ≤ y) : Real.cos y ≤ Real.cos x := by
  exact Real.cos_le_cos_of_nonneg_of_le_pi hx hy hxy

/-! ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    PART 9: MASTER COMPARISON THEOREM — HONEST VERDICT

    Compiles all positive identifications (OEIS finding) and
    distinguishability proofs (Zamolodchikov ≠ framework masses)
    into a single theorem.
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -/

/-- **MASTER:** the OEIS-level identification holds, but the
    Zamolodchikov mass spectrum DOES NOT match framework fermion
    mass ratios at PDG precision.

    POSITIVE results (the OEIS finding is genuine):
      (P1) E8_Coxeter = N_W · N_c · N_total  [atomic identity]
      (P2) E8_exponents.card = N_W ^ N_c     [atomic count]
      (P3) E8_exponents = totatives of 30   [OEIS A005776 ↔ A007775]
      (P4) sum E8_exponents = 120 = N_W^3·N_c·N_total
      (P5) disc = 7 ∈ E8_exponents          [striking]
      (P6) Coxeter angle π/30 = π/(N_W·N_c·N_total)
      (P7) disc = 7 IS the angle multiplier in m_4 and m_7

    NEGATIVE results (no Zamolodchikov-fermion identification):
      (N1) Z_ratio_2 = golden ratio φ ≠ any framework rational
      (N2) m_t/v = 7/10 < 1, but every Z_ratio ≥ 1; disjoint range
      (N3) m_b/m_τ = 7/3 ≈ 2.333 differs from Z_ratio_2 by ≥ 0.7
      (N4) √7 ∉ ℚ(ζ_30), so J₄ irrationals are not in Z spectrum
-/
theorem E8_Ising_Zamolodchikov_master :
    -- POSITIVES (P1)–(P7)
    (E8_Coxeter = N_W * N_c * N_total)
    ∧ (E8_exponents_finset.card = N_W ^ N_c)
    ∧ (∀ k : ℕ, k < 30 → 0 < k →
        (k ∈ E8_exponents_finset ↔ Nat.Coprime k 30))
    ∧ (E8_exponents_finset.sum id = 120)
    ∧ ((120 : ℕ) = N_W ^ 3 * N_c * N_total)
    ∧ (disc ∈ E8_exponents_finset)
    ∧ (Z_ratio_3 = 2 * Real.cos (Real.pi /
                                  (N_W * N_c * N_total : ℝ)))
    ∧ (Z_ratio_4 = (2 * Real.cos (Real.pi / 5)) *
                    (2 * Real.cos ((disc : ℝ) * Real.pi /
                                   (N_W * N_c * N_total : ℝ))))
    -- NEGATIVES (N1)–(N4)
    ∧ ((1.618 : ℝ) < Z_ratio_2 ∧ Z_ratio_2 < 1.619)
    ∧ ((mt_over_v_pred : ℝ) < (1 : ℝ))
    ∧ (Z_ratio_2 + 0.7 < (7 : ℝ) / 3)
    ∧ (¬ ((disc : ℕ) ∣ E8_Coxeter)) := by
  refine ⟨E8_Coxeter_atomic, E8_exponents_card_atomic,
          fun k hk hk0 => E8_oeis_pointwise k hk hk0,
          E8_exponents_finset_sum,
          E8_exponent_sum_atomic,
          disc_in_E8_exponents,
          Z_ratio_3_uses_universal_angle,
          Z_ratio_4_uses_disc,
          Z_ratio_2_bracket,
          mt_v_disjoint_from_Z,
          mb_mtau_ne_Z_ratio_2,
          sqrt7_not_in_Zamolodchikov_field⟩

