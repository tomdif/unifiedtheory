/-- 2 cos(π/5) is positive and less than 2.  Recorded for use below. -/
theorem two_cos_pi_5_pos : 0 < 2 * Real.cos (Real.pi / 5) := by
  have h : 0 < Real.cos (Real.pi / 5) := by
    have hpi : Real.pi / 5 < Real.pi / 2 := by
      have hπ : 0 < Real.pi := Real.pi_pos
      linarith
    have hpi2 : -(Real.pi / 2) < Real.pi / 5 := by
      have hπ : 0 < Real.pi := Real.pi_pos
      linarith
    exact Real.cos_pos_of_mem_Ioo ⟨hpi2, hpi⟩
  linarith

/-- All Zamolodchikov ratios are positive (cos values in (0,1) at the
    relevant angles). -/
theorem all_Z_ratios_positive :
    0 < Z_ratio_1 ∧ 0 < Z_ratio_2 := by
  refine ⟨by unfold Z_ratio_1; norm_num, two_cos_pi_5_pos⟩

