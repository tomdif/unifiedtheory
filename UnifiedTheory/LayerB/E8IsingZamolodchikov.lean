/-! ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    PART 0: FRAMEWORK ATOMS (re-exported)
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -/

abbrev N_W : ℕ := atom_N_W
abbrev N_c : ℕ := atom_N_c
abbrev N_total : ℕ := atom_N_total
abbrev d_eff : ℕ := atom_d_eff
abbrev disc : ℕ := atom_disc

theorem N_W_val : N_W = 2 := rfl
theorem N_c_val : N_c = 3 := rfl
theorem N_total_val : N_total = 5 := rfl
theorem d_eff_val : d_eff = 4 := rfl
theorem disc_val : disc = 7 := rfl

/-! ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    PART 1: E₈ COXETER NUMBER AND EXPONENTS AS A FINSET
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -/

/-- The Coxeter number of E₈, restated here for use without an opaque
    `coxeter_E8` reference.  Numerically 30. -/
def E8_Coxeter : ℕ := 30

/-- E₈ Coxeter number agrees with the value in MagicSquareUnification. -/
theorem E8_Coxeter_eq_coxeter_E8 : E8_Coxeter = coxeter_E8 := rfl

/-- **OEIS-LEVEL ATOMIC IDENTITY: h(E₈) = N_W · N_c · N_total.** -/
theorem E8_Coxeter_atomic : E8_Coxeter = N_W * N_c * N_total := by
  unfold E8_Coxeter N_W N_c N_total atom_N_W atom_N_c atom_N_total
  rfl

/-- The eight Coxeter exponents of E₈ as a `Finset ℕ`. -/
def E8_exponents_finset : Finset ℕ := {1, 7, 11, 13, 17, 19, 23, 29}

/-- The exponent set has cardinality 8. -/
theorem E8_exponents_finset_card : E8_exponents_finset.card = 8 := by
  unfold E8_exponents_finset; decide

/-- **|E₈ exponents| = N_W ^ N_c = 2 ^ 3 = 8.** -/
theorem E8_exponents_card_atomic :
    E8_exponents_finset.card = N_W ^ N_c := by
  unfold E8_exponents_finset N_W N_c atom_N_W atom_N_c
  decide

/-- The exponent set agrees (as a multiset of integers) with the
    list `MagicSquareUnification.E8_exponents`.  We do not formalise
    the list-Finset bijection in detail; both contain the same eight
    values, which is `decide`-able. -/
theorem E8_exponents_finset_membership (k : ℕ) :
    k ∈ E8_exponents_finset ↔
    k = 1 ∨ k = 7 ∨ k = 11 ∨ k = 13 ∨ k = 17 ∨ k = 19 ∨ k = 23 ∨ k = 29 := by
  unfold E8_exponents_finset
  simp [Finset.mem_insert, Finset.mem_singleton]

/-- **disc = 7 IS in the E₈ exponent Finset.**  Re-states
    `MagicSquareUnification.disc_is_E8_exponent` for `Finset` form. -/
theorem disc_in_E8_exponents : disc ∈ E8_exponents_finset := by
  unfold E8_exponents_finset disc atom_disc
  decide

/-- **Sum of E₈ exponents = 120 = N_W^N_c · N_c · N_total.**
    Atomic decomposition matches `MagicSquareUnification.E8_exponent_sum_atomic`. -/
theorem E8_exponents_finset_sum :
    E8_exponents_finset.sum id = 120 := by
  unfold E8_exponents_finset; decide

/-- 120 = N_W ^ N_c · N_c · N_total. -/
theorem E8_exponent_sum_atomic_decomp :
    (120 : ℕ) = N_W ^ N_c * N_c * N_total := by
  unfold N_W N_c N_total atom_N_W atom_N_c atom_N_total
  rfl

/-- 120 = N_W^3 · N_c · N_total (alternative form). -/
theorem E8_exponent_sum_alt :
    (120 : ℕ) = N_W ^ 3 * N_c * N_total :=
  E8_exponent_sum_atomic

/-- Coxeter identity: sum(exponents) · 2 = h · |exponents|.
    For E₈: 120 · 2 = 30 · 8 = 240 = number of roots. -/
theorem E8_Coxeter_sum_identity :
    E8_exponents_finset.sum id * 2 = E8_Coxeter * E8_exponents_finset.card := by
  rw [E8_exponents_finset_sum, E8_Coxeter, E8_exponents_finset_card]

/-! ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    PART 2: THE OEIS FINDING — E₈ EXPONENTS ARE TOTATIVES OF 30

    We prove that for every k ∈ {0,…,29}, membership in
    `E8_exponents_finset` is equivalent to coprimality with 30.

    This is the OEIS A005776 ↔ A007775 (totatives of 30) coincidence,
    which gives the framework atomic identification:

        E8_exponents = (ℤ / (N_W · N_c · N_total) ℤ)*.
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -/

/-- **The CORE OEIS THEOREM:** for every k in {1,…,29}, k is an
    E₈ exponent iff k is coprime to 30.  Both directions decide. -/
theorem E8_exponents_eq_totatives_in_range (k : ℕ) (hk1 : 1 ≤ k)
    (hk2 : k ≤ 29) :
    k ∈ E8_exponents_finset ↔ Nat.Coprime k E8_Coxeter := by
  -- both sides are decidable on the finite range
  unfold E8_exponents_finset E8_Coxeter Nat.Coprime
  interval_cases k <;>
    simp only [Finset.mem_insert, Finset.mem_singleton] <;> decide

/-- **OEIS COINCIDENCE FOR k = 0:** 0 is coprime to nothing > 1, so
    not a totative.  Also not an E₈ exponent. -/
theorem zero_not_in_either :
    (0 : ℕ) ∉ E8_exponents_finset ∧ ¬ Nat.Coprime 0 E8_Coxeter := by
  refine ⟨?_, ?_⟩
  · unfold E8_exponents_finset; decide
  · unfold E8_Coxeter Nat.Coprime; decide

/-- For each k ∈ {1, 2, …, 29}, the membership-coprimality equivalence
    holds (uses interval_cases). -/
theorem E8_oeis_pointwise (k : ℕ) (hk : k < 30) (hk0 : 0 < k) :
    k ∈ E8_exponents_finset ↔ Nat.Coprime k 30 := by
  have hk2 : k ≤ 29 := Nat.lt_succ_iff.mp hk
  have := E8_exponents_eq_totatives_in_range k hk0 hk2
  rwa [show E8_Coxeter = 30 from rfl] at this

/-- **Helper:** the 8 totatives of 30 in {1,…,29} are exactly the
    E₈ exponents, by enumeration. -/
theorem totatives_30_listing : ∀ k : ℕ, k < 30 →
    (Nat.Coprime k 30 ↔ (k = 1 ∨ k = 7 ∨ k = 11 ∨ k = 13 ∨
                         k = 17 ∨ k = 19 ∨ k = 23 ∨ k = 29)) := by
  intro k hk
  unfold Nat.Coprime
  interval_cases k <;> decide

/-- **Cardinality identity:** φ(30) = 8 = N_W^N_c. -/
theorem totient_30_eq_eight : Nat.totient 30 = 8 := by decide

/-- **φ(30) = N_W ^ N_c atomically.** -/
theorem totient_30_atomic : Nat.totient 30 = N_W ^ N_c := by
  unfold N_W N_c atom_N_W atom_N_c
  decide

/-- **MASTER OEIS THEOREM:** the four equivalent forms of the OEIS
    finding, combined into a single theorem. -/
theorem OEIS_master :
    -- (a) h(E₈) = atomic
    E8_Coxeter = N_W * N_c * N_total
    -- (b) totient identity (counts the exponents)
    ∧ Nat.totient 30 = N_W ^ N_c
    -- (c) cardinality of exponent Finset matches φ(30)
    ∧ E8_exponents_finset.card = Nat.totient 30
    -- (d) sum of exponents is atomic (matches MagicSquareUnification)
    ∧ E8_exponents_finset.sum id = 120
    -- (e) disc IS one of the exponents
    ∧ disc ∈ E8_exponents_finset := by
  refine ⟨E8_Coxeter_atomic, totient_30_atomic, ?_,
          E8_exponents_finset_sum, disc_in_E8_exponents⟩
  rw [E8_exponents_finset_card, totient_30_eq_eight]

/-! ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    PART 3: ZAMOLODCHIKOV E₈-ISING MASS RATIOS

    Closed-form definitions of the eight particle masses of the
    Zamolodchikov E₈-Ising integrable QFT (Zamolodchikov 1989).
    All ratios are normalised to m_1, the lightest mass.
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -/

/-- **m_1 / m_1 = 1.**  Sets the scale. -/
noncomputable def Z_ratio_1 : ℝ := 1

/-- **m_2 / m_1 = 2 cos(π/5).**  Exactly the golden ratio φ = (1+√5)/2. -/
noncomputable def Z_ratio_2 : ℝ := 2 * Real.cos (Real.pi / 5)

/-- **m_3 / m_1 = 2 cos(π/30).**  Uses the universal Coxeter angle
    π / h(E₈). -/
noncomputable def Z_ratio_3 : ℝ := 2 * Real.cos (Real.pi / 30)

/-- **m_4 / m_1 = 2 cos(π/5) · 2 cos(7π/30).**  The integer 7 = disc
    appears explicitly in the second factor. -/
noncomputable def Z_ratio_4 : ℝ :=
  (2 * Real.cos (Real.pi / 5)) * (2 * Real.cos (7 * Real.pi / 30))

/-- **m_5 / m_1 = 4 cos(π/5) · cos(2π/15).** -/
noncomputable def Z_ratio_5 : ℝ :=
  4 * Real.cos (Real.pi / 5) * Real.cos (2 * Real.pi / 15)

/-- **m_6 / m_1 = 4 cos(π/5) · cos(π/30).** -/
noncomputable def Z_ratio_6 : ℝ :=
  4 * Real.cos (Real.pi / 5) * Real.cos (Real.pi / 30)

/-- **m_7 / m_1 = 8 cos²(π/5) · cos(7π/30).**  Again uses the
    7π/30 = (disc · π)/h(E₈) angle. -/
noncomputable def Z_ratio_7 : ℝ :=
  8 * (Real.cos (Real.pi / 5))^2 * Real.cos (7 * Real.pi / 30)

/-- **m_8 / m_1 = 8 cos²(π/5) · cos(2π/15).** -/
noncomputable def Z_ratio_8 : ℝ :=
  8 * (Real.cos (Real.pi / 5))^2 * Real.cos (2 * Real.pi / 15)

/-- The eight Zamolodchikov ratios collected as a list. -/
noncomputable def Zamolodchikov_ratios : List ℝ :=
  [Z_ratio_1, Z_ratio_2, Z_ratio_3, Z_ratio_4,
   Z_ratio_5, Z_ratio_6, Z_ratio_7, Z_ratio_8]

/-- Length of the Zamolodchikov-ratio list = 8 = rank(E₈). -/
theorem Zamolodchikov_ratios_length :
    Zamolodchikov_ratios.length = N_W ^ N_c := by
  unfold Zamolodchikov_ratios N_W N_c atom_N_W atom_N_c
  decide

/-- **The angle π/h(E₈) = π/30 is the universal Coxeter angle.**
    Records that the irrational structure of the masses is built from
    the angle π divided by the SAME Coxeter number h(E₈) = 30 that is
    atomic in framework atoms (= N_W · N_c · N_total). -/
theorem Z_ratio_3_uses_universal_angle :
    Z_ratio_3 = 2 * Real.cos (Real.pi / (N_W * N_c * N_total : ℝ)) := by
  unfold Z_ratio_3 N_W N_c N_total atom_N_W atom_N_c atom_N_total
  norm_num

/-- **disc = 7 appears in m_4 and m_7 as the multiplier of π/30.** -/
theorem Z_ratio_4_uses_disc :
    Z_ratio_4 =
      (2 * Real.cos (Real.pi / 5)) *
      (2 * Real.cos ((disc : ℝ) * Real.pi /
                     (N_W * N_c * N_total : ℝ))) := by
  unfold Z_ratio_4 disc atom_disc N_W N_c N_total
         atom_N_W atom_N_c atom_N_total
  norm_num

/-- **Universal-angle restatement of m_7.** -/
theorem Z_ratio_7_uses_disc :
    Z_ratio_7 =
      8 * (Real.cos (Real.pi / 5))^2 *
      Real.cos ((disc : ℝ) * Real.pi / (N_W * N_c * N_total : ℝ)) := by
  unfold Z_ratio_7 disc atom_disc N_W N_c N_total
         atom_N_W atom_N_c atom_N_total
  norm_num

/-! ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    PART 4: NUMERICAL BRACKETS OF Z_ratio_k

    The Zamolodchikov ratios are transcendental; we bracket their
    numerical values using `cos` monotonicity bounds.

