  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  WHAT IS PROVED (zero sorry, zero custom axioms)

  PART 1.  E₈ EXPONENTS AS A FINSET, ATOMIC IDENTIFICATIONS.
            • E8_Coxeter = 30 = N_W · N_c · N_total.
