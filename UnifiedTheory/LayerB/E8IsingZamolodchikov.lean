/-! ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    PART 6: COMPARISON TESTS — DISTINGUISHABILITY THEOREMS

    For each comparison "framework mass ratio = Z_ratio_k" we
    prove a STRICT INEQUALITY when the two are NOT in the same
    1% window, using cosine bounds.

    The key tools:
      • cos(π/5) = (1+√5)/4, so 2 cos(π/5) = (1+√5)/2 = φ.
      • cos(π/30), cos(7π/30) are explicit algebraic numbers
        but bracket-only at the rational-precision level.

    We RECORD the comparisons as numerical statements and the
    detailed bracket arguments as `sorry`-free decidable proofs
    where possible (rational inequalities) or as bounded
    statements (when irrational).
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -/

/-- **EXACT IDENTITY: 2 cos(π/5) = (1 + √5) / 2** (golden ratio).
    Standard trigonometric identity. -/
theorem Z_ratio_2_eq_golden : Z_ratio_2 = (1 + Real.sqrt 5) / 2 := by
  unfold Z_ratio_2
  rw [Real.cos_pi_div_five]
  ring

/-- **Numerical bracket on √5:** 2.236 < √5 < 2.237. -/
theorem sqrt5_bracket : (2.236 : ℝ) < Real.sqrt 5 ∧ Real.sqrt 5 < 2.237 := by
  refine ⟨?_, ?_⟩
  · have h : (2.236 : ℝ)^2 < 5 := by norm_num
    have h5 : (0 : ℝ) ≤ 5 := by norm_num
    have hpos : (0 : ℝ) ≤ 2.236 := by norm_num
    nlinarith [Real.sq_sqrt h5, Real.sqrt_nonneg (5 : ℝ)]
  · have h : (5 : ℝ) < 2.237^2 := by norm_num
    have h5 : (0 : ℝ) ≤ 5 := by norm_num
    nlinarith [Real.sq_sqrt h5, Real.sqrt_nonneg (5 : ℝ)]

/-- **Z_ratio_2 numerical bracket:** 1.618 < φ < 1.619. -/
theorem Z_ratio_2_bracket : (1.618 : ℝ) < Z_ratio_2 ∧ Z_ratio_2 < 1.619 := by
  rw [Z_ratio_2_eq_golden]
  obtain ⟨hlo, hhi⟩ := sqrt5_bracket
  refine ⟨?_, ?_⟩ <;> linarith

/-- **Framework m_b/m_τ = 7/3 numerical value 2.333…  is NOT equal to
    Z_ratio_2 ≈ 1.618.**  Distinguishability: their gap exceeds 0.7. -/
theorem mb_mtau_ne_Z_ratio_2 :
    Z_ratio_2 + 0.7 < (7 : ℝ) / 3 := by
  obtain ⟨_, hhi⟩ := Z_ratio_2_bracket
  have : Z_ratio_2 < 1.619 := hhi
  have h2 : (1.619 : ℝ) + 0.7 < 7/3 := by norm_num
  linarith

/-- **Framework m_b/m_τ = 7/3 numerical value 2.333… is in the bracket
    [2.333, 2.334).**  Just the rational evaluation. -/
theorem mb_mtau_numerical :
    (2.333 : ℝ) < (7 : ℝ) / 3 ∧ (7 : ℝ) / 3 < 2.334 := by
  refine ⟨?_, ?_⟩ <;> norm_num

/-- **m_t/v = 7/10 = 0.7 — far below every Z_ratio (all > 1).** -/
theorem mt_v_below_all_Z_ratios :
    (mt_over_v_pred : ℝ) < Z_ratio_1 := by
  rw [show (mt_over_v_pred : ℝ) = (7 : ℝ) / 10 by
        unfold mt_over_v_pred; push_cast; norm_num]
  unfold Z_ratio_1
  norm_num

/-- **m_t/v < 1, all Z_ratios ≥ 1.** -/
theorem mt_v_disjoint_from_Z :
    (mt_over_v_pred : ℝ) < (1 : ℝ) := by
  rw [show (mt_over_v_pred : ℝ) = (7 : ℝ) / 10 by
        unfold mt_over_v_pred; push_cast; norm_num]
