              m_1 / m_1 = 1
              m_2 / m_1 = 2 cos(π/5)              ≈ 1.61803... (= φ)
              m_3 / m_1 = 2 cos(π/30)             ≈ 1.98904
              m_4 / m_1 = (2 cos(π/5)) · (2 cos(7π/30))   ≈ 2.40487
              m_5 / m_1 = 4 cos(π/5) · cos(2π/15)         ≈ 2.95630
              m_6 / m_1 = 4 cos(π/5) · cos(π/30)          ≈ 3.21834
